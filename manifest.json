{
  "manifest_version": 3,
  "name": "Bugatti Chiron Scrollbar",
  "version": "15.0",
  "description": "Bugatti Chiron top-view races your scrollbar with gear shifting, HID headlights & spinning wheels!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage"
  ]
}